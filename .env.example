# =============================================================================
# Umbra PiVPN Manager - Environment Configuration
# =============================================================================

# =============================================================================
# Backend Configuration
# =============================================================================

# Server port (default: 8080)
PORT=8080

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin Credentials
# For development, you can use plain text (not recommended for production)
# For production, use bcrypt hash: htpasswd -nbB admin yourpassword
ADMIN_USERNAME=admin
# Plain text password (development only) - OR - bcrypt hash
ADMIN_PASSWORD=admin
# ADMIN_PASSWORD_HASH=$2y$10$... (bcrypt hash for production)

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# CORS Origins (comma-separated, no spaces)
# Development: http://localhost:3000,http://127.0.0.1:3000
# Production: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Request Rate Limiting
# Format: requests per second:burst size
RATE_LIMIT=10:20

# Request Timeout (seconds)
REQUEST_TIMEOUT=30

# =============================================================================
# Frontend Configuration
# =============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# =============================================================================
# PiVPN Configuration
# =============================================================================

# Path to WireGuard configurations
WIREGUARD_CONFIG_PATH=/etc/wireguard

# WireGuard interface name
WIREGUARD_INTERFACE=wg0

# =============================================================================
# Security Settings
# =============================================================================

# Enable secure mode (stricter validation, no debug info)
# Set to "true" in production
SECURE_MODE=false

# Token expiration time (hours)
TOKEN_EXPIRY_HOURS=24

# =============================================================================
# Docker Configuration
# =============================================================================

# Docker Network (optional)
# DOCKER_NETWORK=umbra-network

# Volume mounts (optional)
# WIREGUARD_VOLUME=/etc/wireguard
