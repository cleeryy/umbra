FROM golang:1.21-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache \
    wireguard-tools \
    iptables \
    bash

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY cmd/ ./cmd/
COPY internal/ ./internal/

# Build the application
RUN go build -o pivpn-api ./cmd/api/main.go

# Create non-root user
RUN adduser -D -u 1000 pivpn-user
RUN chown -R pivpn-user:pivpn-user /app
USER pivpn-user

EXPOSE 8080

CMD ["./pivpn-api"]